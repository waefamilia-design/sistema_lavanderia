*.rptproj.bak
MigrationBackup/

# SQL Server
*.mdf
*.ldf
*.ndf

# Node
node_modules/

# Python
**/__pycache__/
*.pyc

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Local History
.history/
.vshistory/
**/.localhistory/

# AWS SAM
.aws-sam

# Built VS Code Extensions
*.vsix

# Windows Installer
*.cab
*.msi
*.msix
*.msm
*.msp

