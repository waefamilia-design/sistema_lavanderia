@model SistemaLavanderia.Models.Pedido

@{
    ViewData["Title"] = "Detalhes do Pedido #" + Model.Id;
}

<div class="container mt-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 d-print-none">
        <h2 class="fw-black mb-0"><i class="bi bi-receipt text-primary me-2"></i>Detalhes do Pedido</h2>
        <div class="d-flex gap-2">
            <button onclick="window.print()" class="btn btn-outline-dark rounded-pill">
                <i class="bi bi-printer-fill me-1"></i> Imprimir Recibo
            </button>
            <a asp-action="Index" class="btn btn-primary rounded-pill">
                <i class="bi bi-arrow-left me-1"></i> Voltar
            </a>
        </div>
    </div>

    <div class="card-modern shadow-lg border-0 overflow-hidden">
        <!-- Header do Recibo -->
        <div class="bg-primary text-white p-4 d-flex justify-content-between align-items-center">
            <div>
                <h3 class="fw-black mb-0">🧺 Clean T-Shirt</h3>
                <p class="mb-0 opacity-75">Sua lavanderia professional</p>
            </div>
            <div class="text-end">
                <h4 class="mb-0">PEDIDO #@Model.Id.ToString("D5")</h4>
                <p class="mb-0 opacity-75">@Model.DataEntrada.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>

        <div class="card-body p-4 p-md-5">
            <div class="row mb-5">
                <div class="col-sm-6 mb-4 mb-sm-0">
                    <h6 class="text-muted text-uppercase small fw-bold mb-3">Dados do Cliente</h6>
                    <h5 class="fw-bold mb-1">@Model.Cliente?.Nome</h5>
                    <p class="text-muted mb-0">CPF: @Model.Cliente?.Cpf</p>
                    <p class="text-muted mb-0">Tel: @Model.Cliente?.Telefone</p>
                </div>
                <div class="col-sm-6 text-sm-end">
                    <h6 class="text-muted text-uppercase small fw-bold mb-3">Informações de Entrega</h6>
                    <p class="mb-1"><strong>Status:</strong> <span class="badge @(Model.Status == "Entregue" ? "bg-success" : "bg-warning") rounded-pill px-3">@Model.Status</span></p>
                    <p class="mb-1"><strong>Previsão:</strong> @(Model.DataEntrega?.ToString("dd/MM/yyyy") ?? "A definir")</p>
                    <p class="mb-0"><strong>Tipo:</strong> @Model.TipoLavagem</p>
                </div>
            </div>

            <!-- Tabela de Itens -->
            <div class="table-responsive mb-5">
                <table class="table table-borderless border-top border-bottom">
                    <thead class="bg-light">
                        <tr>
                            <th class="py-3">Serviço / Peça</th>
                            <th class="py-3 text-center">Qtd</th>
                            <th class="py-3 text-end">Preço Unit.</th>
                            <th class="py-3 text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.ItensPedido)
                        {
                            <tr>
                                <td class="py-3 fw-bold">@item.TipoPeca</td>
                                <td class="py-3 text-center">@item.Quantidade</td>
                                <td class="py-3 text-end">@item.ValorUnitario.ToString("C")</td>
                                <td class="py-3 text-end fw-bold">@item.Subtotal.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="row justify-content-end">
                <div class="col-md-5 col-lg-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Total de Peças:</span>
                        <span class="fw-bold">@Model.Quantidade</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4 pb-2 border-bottom">
                        <span class="text-muted">Status Pagamento:</span>
                        <span class="badge @(Model.StatusPagamento == "Pago" ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") px-3">@Model.StatusPagamento</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="fw-bold text-muted mb-0">TOTAL</h4>
                        <h2 class="fw-black text-primary mb-0">@Model.Valor.ToString("C")</h2>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Observacoes))
            {
                <div class="mt-5 p-3 bg-light rounded-4">
                    <h6 class="fw-bold mb-2 small text-uppercase text-muted">Observações</h6>
                    <p class="mb-0 italic">"@Model.Observacoes"</p>
                </div>
            }
        </div>

        <div class="card-footer bg-light p-4 text-center border-0">
            <p class="text-muted small mb-0">Obrigado pela preferência! Clean T-Shirt - Qualidade em cada detalhe.</p>
        </div>
    </div>
</div>

<style>
    @@media print {
        .navbar, .d-print-none, .whatsapp-float, footer { display: none !important; }
        body { background: white !important; }
        .container { max-width: 100% !important; margin: 0 !important; padding: 0 !important; }
        .card-modern { box-shadow: none !important; border: 1px solid #eee !important; }
    }
    
    .bg-success-subtle { background-color: rgba(16, 185, 129, 0.1) !important; }
    .bg-danger-subtle { background-color: rgba(239, 68, 68, 0.1) !important; }
</style>
