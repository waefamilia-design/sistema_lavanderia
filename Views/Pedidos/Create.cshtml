@model SistemaLavanderia.Models.PedidoCreateViewModel
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Nova Solicitação";
    var servicos = ViewBag.Servicos as List<SistemaLavanderia.Models.Servico>;
    var perfil = ViewBag.Perfil as string;
}

<div class="container mt-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-black mb-0"><i class="bi bi-plus-circle-fill text-primary me-2"></i>Nova Solicitação</h2>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-arrow-left me-1"></i> Voltar
        </a>
    </div>

    <form asp-action="Create" method="post" id="pedidoForm">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 shadow-sm mb-4"></div>

        <div class="row g-4">
            <!-- Informações do Cliente -->
            <div class="col-lg-8">
                <div class="card-modern p-4 mb-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2"><i class="bi bi-person-fill text-primary me-2"></i>Informações do Cliente</h5>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ClienteId" class="form-label fw-semibold">Cliente</label>
                            @if (perfil == "Administrador")
                            {
                                <select asp-for="ClienteId" class="form-select form-control-modern" asp-items="ViewBag.ClienteId">
                                    <option value="">Selecione o cliente...</option>
                                </select>
                            }
                            else
                            {
                                <select asp-for="ClienteId" class="form-select form-control-modern bg-light" asp-items="ViewBag.ClienteId" readonly>
                                </select>
                            }
                            <span asp-validation-for="ClienteId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TipoLavagem" class="form-label fw-semibold">Tipo de Lavagem</label>
                            <select asp-for="TipoLavagem" class="form-select form-control-modern">
                                <option value="Padrão">Padrão (Água e Sabão)</option>
                                <option value="Delicada">Delicada / À Mão</option>
                                <option value="A Seco">Lavagem a Seco Professional</option>
                                <option value="Premium">Premium (Tratamento de Manchas)</option>
                            </select>
                            <span asp-validation-for="TipoLavagem" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DataEntrega" class="form-label fw-semibold">Previsão de Entrega</label>
                            <input asp-for="DataEntrega" type="date" class="form-control form-control-modern" value="@DateTime.Today.AddDays(3).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="DataEntrega" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Observacoes" class="form-label fw-semibold">Observações Especiais</label>
                            <textarea asp-for="Observacoes" class="form-control form-control-modern" rows="2" placeholder="Ex: Mancha de café na gola, tecido frágil..."></textarea>
                        </div>
                    </div>
                </div>

                <!-- Seleção de Itens -->
                <div class="card-modern p-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2"><i class="bi bi-cart-plus-fill text-primary me-2"></i>Seleção de Peças</h5>
                    
                    <div class="table-responsive">
                        <table class="table table-hover align-middle" id="tabelaItens">
                            <thead class="bg-light">
                                <tr>
                                    <th>Peça / Serviço</th>
                                    <th style="width: 150px;">Quantidade</th>
                                    <th class="text-end">Preço Unit.</th>
                                    <th class="text-end">Subtotal</th>
                                    <th style="width: 50px;"></th>
                                </tr>
                            </thead>
                            <tbody id="itensContainer">
                                <!-- Itens adicionados aparecerão aqui -->
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <button type="button" class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#modalServicos">
                            <i class="bi bi-plus-lg me-1"></i> Adicionar Peça
                        </button>
                        <div class="text-end">
                            <p class="text-muted mb-0 small">Total de Peças: <span id="totalPecas" class="fw-bold">0</span></p>
                            <h3 class="fw-black text-primary mb-0">Total: <span id="valorTotal">R$ 0,00</span></h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Coluna Lateral - Resumo/Dicas -->
            <div class="col-lg-4">
                <div class="card-modern p-4 mb-4 bg-primary text-white border-0 shadow-lg">
                    <h5 class="fw-bold mb-3"><i class="bi bi-lightning-fill me-2"></i>Dicas Clean T-Shirt</h5>
                    <ul class="list-unstyled small mb-0">
                        <li class="mb-2"><i class="bi bi-check2-circle me-2"></i> Peças delicadas levam +2 dias.</li>
                        <li class="mb-2"><i class="bi bi-check2-circle me-2"></i> Lavagem por KG é ideal para roupas do dia a dia.</li>
                        <li class="mb-2"><i class="bi bi-check2-circle me-2"></i> Verifique sempre os bolsos antes de enviar!</li>
                    </ul>
                </div>

                <div class="card-modern p-4">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">Finalizar</h5>
                    <p class="small text-muted mb-4">Ao finalizar, seu pedido será registrado e entraremos em contato via WhatsApp para confirmar a retirada.</p>
                    <button type="submit" class="btn btn-success w-100 py-3 rounded-pill fw-bold shadow-sm mb-3">
                        <i class="bi bi-check-lg me-1"></i> Confirmar Solicitação
                    </button>
                    <div class="alert alert-info py-2 px-3 small rounded-3 mb-0">
                        <i class="bi bi-info-circle me-1"></i> O pagamento é realizado na entrega das roupas.
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Modal de Serviços -->
<div class="modal fade" id="modalServicos" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 shadow-lg border-0">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Escolha a Peça</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="list-group list-group-flush">
                    @if (servicos != null)
                    {
                        @foreach (var s in servicos)
                        {
                            <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3"
                                    onclick="adicionarItem(@s.Id, '@s.Nome', @s.PrecoBase.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))">
                                <div>
                                    <span class="fw-bold">@s.Nome</span>
                                    <div class="small text-muted">@s.Descricao</div>
                                </div>
                                <span class="badge bg-primary-subtle text-primary rounded-pill px-3">@s.PrecoBase.ToString("C")</span>
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        let itemCount = 0;

        function adicionarItem(id, nome, preco) {
            const container = document.getElementById('itensContainer');
            
            // Verifica se o item já existe na lista
            const itemExistente = document.querySelector(`.item-row[data-servico-id="${id}"]`);
            if (itemExistente) {
                const input = itemExistente.querySelector('.item-qtd');
                input.value = parseInt(input.value) + 1;
                atualizarSubtotal(input);
                bootstrap.Modal.getInstance(document.getElementById('modalServicos')).hide();
                return;
            }

            // Pega o multiplicador baseado no tipo de lavagem
            const tipoLavagem = document.getElementById('TipoLavagem').value;
            let multiplicador = 1.0;
            
            switch(tipoLavagem) {
                case 'Delicada': multiplicador = 1.25; break; // +25%
                case 'A Seco': multiplicador = 1.5; break;    // +50%
                case 'Premium': multiplicador = 2.0; break;   // +100%
            }

            const precoFinal = preco * multiplicador;

            const tr = document.createElement('tr');
            tr.className = 'item-row fade-in';
            tr.setAttribute('data-servico-id', id);
            
            tr.innerHTML = `
                <td>
                    <span class="fw-bold">${nome}</span>
                    <input type="hidden" name="Itens[${itemCount}].ServicoId" value="${id}" />
                    <input type="hidden" name="Itens[${itemCount}].NomeServico" value="${nome}" />
                </td>
                <td>
                    <div class="input-group input-group-sm">
                        <button class="btn btn-outline-secondary" type="button" onclick="mudarQtd(this, -1)">-</button>
                        <input type="number" name="Itens[${itemCount}].Quantidade" 
                               class="form-control text-center item-qtd" value="1" min="1" 
                               onchange="atualizarSubtotal(this)" />
                        <button class="btn btn-outline-secondary" type="button" onclick="mudarQtd(this, 1)">+</button>
                    </div>
                </td>
                <td class="text-end">
                    <span class="text-muted small">R$ ${precoFinal.toFixed(2)}</span>
                    <input type="hidden" class="item-preco" name="Itens[${itemCount}].PrecoUnitario" value="${precoFinal}" />
                </td>
                <td class="text-end">
                    <span class="fw-bold text-primary subtotal">R$ ${precoFinal.toFixed(2)}</span>
                </td>
                <td>
                    <button type="button" class="btn btn-link text-danger p-0" onclick="removerItem(this)">
                        <i class="bi bi-x-circle-fill"></i>
                    </button>
                </td>
            `;

            container.appendChild(tr);
            itemCount++;
            atualizarTotal();
            
            // Fecha o modal
            bootstrap.Modal.getInstance(document.getElementById('modalServicos')).hide();
        }

        // Atualiza os preços se o usuário mudar o tipo de lavagem após já ter itens na lista
        document.getElementById('TipoLavagem').addEventListener('change', function() {
            // Opcional: Avisar o usuário ou recalcular tudo
            // Para ser simples, vamos limpar a lista ou apenas atualizar os subtotais dos itens existentes
            const itens = document.querySelectorAll('.item-row');
            if (itens.length > 0) {
                alert("O tipo de lavagem foi alterado. Para aplicar os novos preços aos itens já adicionados, remova-os e adicione novamente.");
            }
        });

        function mudarQtd(btn, delta) {
            const input = btn.parentElement.querySelector('.item-qtd');
            let novaQtd = parseInt(input.value) + delta;
            if (novaQtd < 1) novaQtd = 1;
            input.value = novaQtd;
            atualizarSubtotal(input);
        }

        function atualizarSubtotal(input) {
            const row = input.closest('tr');
            const preco = parseFloat(row.querySelector('.item-preco').value);
            const qtd = parseInt(input.value);
            const subtotal = preco * qtd;
            row.querySelector('.subtotal').innerText = subtotal.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            atualizarTotal();
        }

        function removerItem(btn) {
            btn.closest('tr').remove();
            atualizarTotal();
        }

        function atualizarTotal() {
            let total = 0;
            let totalPecas = 0;
            document.querySelectorAll('.item-row').forEach(row => {
                const preco = parseFloat(row.querySelector('.item-preco').value);
                const qtd = parseInt(row.querySelector('.item-qtd').value);
                total += preco * qtd;
                totalPecas += qtd;
            });

            document.getElementById('valorTotal').innerText = total.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            document.getElementById('totalPecas').innerText = totalPecas;
        }
    </script>
}
