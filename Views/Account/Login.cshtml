@model SistemaLavanderia.Models.LoginViewModel

@{
    ViewData["Title"] = "Entrar";
}

<div class="auth-container fade-in">
    <div class="auth-card">
        <div class="auth-header">
            <div class="mb-3 text-primary display-6">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h2>Bem-vindo de volta</h2>
            <p class="text-muted">Acesse sua conta para gerenciar pedidos.</p>
        </div>

        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-success mb-4 d-flex align-items-center fade show">
                <i class="bi bi-check-circle-fill me-2"></i>
                <div>@TempData["Sucesso"]</div>
            </div>
        }

        @if (ViewBag.Erro != null)
        {
            <div class="alert alert-danger mb-4 d-flex align-items-center fade show">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <div>@ViewBag.Erro</div>
            </div>
        }

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <form asp-action="Login" method="post">
            <div class="form-floating mb-3">
                <input asp-for="Login" class="form-control form-control-modern" placeholder="Login" required />
                <label asp-for="Login">Usuário</label>
                <span asp-validation-for="Login" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="Senha" class="form-control form-control-modern" type="password" placeholder="Senha" required />
                <label asp-for="Senha">Senha</label>
                <span asp-validation-for="Senha" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow mb-3">
                Entrar no Sistema
            </button>
        </form>

        <div class="text-center mt-4 pt-3 border-top">
            <p class="text-muted mb-0">Novo por aqui?</p>
            <a asp-action="Register" class="text-primary fw-bold text-decoration-none">
                Criar uma Conta <i class="bi bi-chevron-right small"></i>
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}