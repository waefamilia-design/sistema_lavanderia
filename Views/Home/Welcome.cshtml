@{
    ViewData["Title"] = "Bem-vindo";
}

<div class="welcome-container fade-in">
    <!-- Hero Section -->
    <header class="hero-section text-center py-5 mb-5">
        <div class="container">
            <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-3 fw-bold" data-i18n="hero-badge">
                <i class="bi bi-stars me-1"></i> A Melhor Gestão para sua Lavanderia
            </span>
            <h1 class="display-3 fw-black mb-4 tracking-tight" data-i18n="welcome-title">
                Lavanderia <span class="text-primary">Clean T-Shirt</span>
            </h1>
            <p class="lead text-secondary mx-auto mb-5" style="max-width: 700px;" data-i18n="welcome-subtitle">
                Simplifique seu negócio com nossa plataforma inteligente. Controle total de pedidos, clientes e serviços em um só lugar.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow-lg" data-i18n="btn-start">
                    Começar Agora <i class="bi bi-arrow-right ms-2"></i>
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-dark btn-lg px-5 py-3 rounded-pill fw-bold" data-i18n="btn-create-acc">
                    Criar Conta Grátis
                </a>
            </div>
        </div>
    </header>

    <!-- Features Section -->
    <section class="features-section py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card-modern p-4 h-100">
                        <div class="icon-box bg-primary-subtle text-primary mb-3">
                            <i class="bi bi-lightning-charge-fill"></i>
                        </div>
                        <h4 class="fw-bold mb-3" data-i18n="feat-1-title">Rapidez e Eficiência</h4>
                        <p class="text-muted mb-0" data-i18n="feat-1-desc">Cadastre pedidos em segundos e acompanhe o status em tempo real.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card-modern p-4 h-100">
                        <div class="icon-box bg-success-subtle text-success mb-3">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <h4 class="fw-bold mb-3" data-i18n="feat-2-title">Segurança Total</h4>
                        <p class="text-muted mb-0" data-i18n="feat-2-desc">Seus dados e de seus clientes protegidos com a melhor tecnologia.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card-modern p-4 h-100">
                        <div class="icon-box bg-info-subtle text-info mb-3">
                            <i class="bi bi-graph-up"></i>
                        </div>
                        <h4 class="fw-bold mb-3" data-i18n="feat-3-title">Visão do Negócio</h4>
                        <p class="text-muted mb-0" data-i18n="feat-3-desc">Relatórios detalhados para você tomar as melhores decisões.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section py-5 my-5">
        <div class="container bg-white rounded-5 p-5 shadow-sm border">
            <div class="row text-center g-4">
                <div class="col-6 col-md-3">
                    <h2 class="fw-black text-primary mb-1">500+</h2>
                    <p class="text-muted fw-semibold small text-uppercase tracking-wider" data-i18n="stat-clients">Clientes</p>
                </div>
                <div class="col-6 col-md-3">
                    <h2 class="fw-black text-primary mb-1">10k+</h2>
                    <p class="text-muted fw-semibold small text-uppercase tracking-wider" data-i18n="stat-orders">Pedidos</p>
                </div>
                <div class="col-6 col-md-3">
                    <h2 class="fw-black text-primary mb-1">99%</h2>
                    <p class="text-muted fw-semibold small text-uppercase tracking-wider" data-i18n="stat-satisfaction">Satisfação</p>
                </div>
                <div class="col-6 col-md-3">
                    <h2 class="fw-black text-primary mb-1">24/7</h2>
                    <p class="text-muted fw-semibold small text-uppercase tracking-wider" data-i18n="stat-support">Suporte</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section py-5 mb-5">
        <div class="container">
            <div class="cta-card p-5 text-center shadow-lg position-relative overflow-hidden">
                <div class="position-relative z-1 py-4">
                    <h2 class="display-4 fw-black mb-4 text-white" data-i18n="cta-title">Pronto para transformar sua lavanderia?</h2>
                    <p class="lead mb-5 text-white opacity-75 mx-auto" style="max-width: 600px;" data-i18n="cta-desc">
                        Junte-se a centenas de empreendedores que já profissionalizaram seu atendimento com a Clean T-Shirt.
                    </p>
                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm" data-i18n="cta-btn-start">
                            Começar Agora Gratuitamente
                        </a>
                        <a href="https://wa.me/5511999999999" target="_blank" class="btn btn-outline-light btn-lg px-5 py-3 rounded-pill fw-bold" data-i18n="cta-btn-support">
                            <i class="bi bi-whatsapp me-2"></i> Falar com Suporte
                        </a>
                    </div>
                </div>
                <!-- Background Decorative Elements -->
                <div class="cta-overlay"></div>
                <div class="cta-circles">
                    <div class="circle circle-1"></div>
                    <div class="circle circle-2"></div>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    .fw-black { font-weight: 900; }
    .tracking-tight { letter-spacing: -0.05em; }
    
    .cta-card {
        background: linear-gradient(135deg, #0f172a 0%, #1e40af 100%);
        border-radius: 2.5rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .cta-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.05) 1px, transparent 0);
        background-size: 32px 32px;
    }

    .cta-circles {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        pointer-events: none;
    }

    .circle {
        position: absolute;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.2), transparent);
    }

    .circle-1 {
        width: 400px;
        height: 400px;
        top: -200px;
        right: -100px;
    }

    .circle-2 {
        width: 300px;
        height: 300px;
        bottom: -150px;
        left: -50px;
    }

    .icon-box {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .z-1 { z-index: 1; }
</style>