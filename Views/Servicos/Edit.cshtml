@model SistemaLavanderia.Models.Servico

@{
    ViewData["Title"] = "Editar Serviço";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-warning text-dark p-3">
                    <h4 class="mb-0"><i class="bi bi-pencil-fill me-2"></i>Editar Serviço</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label fw-bold">Nome do Serviço</label>
                            <input asp-for="Nome" class="form-control" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descricao" class="form-label fw-bold">Descrição</label>
                            <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Descricao" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="PrecoBase" class="form-label fw-bold">Preço Base (R$)</label>
                                <input asp-for="PrecoBase" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="PrecoBase" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="UnidadeMedida" class="form-label fw-bold">Unidade de Medida</label>
                                <select asp-for="UnidadeMedida" class="form-select">
                                    <option value="Peça">Peça</option>
                                    <option value="Kg">Kg</option>
                                    <option value="Par">Par</option>
                                    <option value="M²">M²</option>
                                    <option value="Unidade">Unidade</option>
                                </select>
                                <span asp-validation-for="UnidadeMedida" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input asp-for="Ativo" class="form-check-input" type="checkbox" />
                                <label asp-for="Ativo" class="form-check-label fw-bold">Serviço Ativo</label>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning px-4">
                                <i class="bi bi-save me-1"></i> Salvar Alterações
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left me-1"></i> Voltar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
