@model List<SistemaLavanderia.Models.Servico>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Serviços de Lavanderia";
    var usuarioPerfil = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioPerfil");
    var isAdmin = usuarioPerfil == "Administrador";
}

<div class="container mt-4 servicos-page">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="servicos-title mb-0">Serviços de Lavanderia</h1>
        @if (isAdmin)
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg"></i> Novo Serviço
            </a>
        }
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="servicos-table-header bg-dark text-white">
                        <tr>
                            <th>Nome</th>
                            <th>Descrição</th>
                            <th>Preço Base</th>
                            <th>Unidade</th>
                            @if (isAdmin)
                            {
                                <th class="text-center">Ações</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var servico in Model)
                        {
                            <tr>
                                <td><strong>@servico.Nome</strong></td>
                                <td>@servico.Descricao</td>
                                <td>@servico.PrecoBase.ToString("C")</td>
                                <td>@servico.UnidadeMedida</td>
                                @if (isAdmin)
                                {
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Edit" asp-route-id="@servico.Id" class="btn btn-outline-warning" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@servico.Id" class="btn btn-outline-danger" title="Excluir">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!isAdmin)
    {
        <div class="alert alert-info mt-4">
            <i class="bi bi-info-circle-fill"></i>
            Para solicitar um serviço, clique em <strong>"Solicitar Serviço"</strong> no menu superior.
        </div>
    }
</div>
